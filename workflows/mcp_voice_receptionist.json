    {
      "id": "aaaaaaaa-0004-0004-0004-000000000004",
      "name": "Process CRM Lookup Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1000, 120],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Grab all rows returned by Google Sheets\nconst rows = $input.all();\n\nif (rows.length === 0 || !rows[0].json || !rows[0].json.Email) {\n  // No matching record found – treat as new client\n  return [{\n    json: {\n      status: 'new_client',\n      message: 'New Client',\n      found: false\n    }\n  }];\n}\n\n// Client exists in CRM\nconst row = rows[0].json;\nreturn [{\n  json: {\n    status: 'existing_client',\n    found: true,\n    name: row.Name || '',\n    email: row.Email || '',\n    phone: row.Phone || '',\n    clientStatus: row.Status || 'Active',\n    message: `Client found: ${row.Name}, Status: ${row.Status || 'Active'}`\n  }\n}];"
      }
    },

