      "id": "aaaaaaaa-0012-0012-0012-000000000012",
      "name": "Booking Log Lookup",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [740, 800],
      "credentials": { "googleSheetsOAuth2Api": { "id": "REPLACE_WITH_CREDENTIAL_ID", "name": "Google Sheets Account" } },
      "parameters": {
        "operation": "readOrSearch",
        "documentId": { "__rl": true, "value": "REPLACE_WITH_BOOKING_LOG_SPREADSHEET_ID", "mode": "id" },
        "sheetName": { "__rl": true, "value": "gid=0", "mode": "list", "cachedResultName": "BookingLog" },
        "filtersUI": {
