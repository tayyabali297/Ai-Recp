    {
      "id": "aaaaaaaa-0013-0013-0013-000000000013",
      "name": "Process Appointment Lookup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1000, 800],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rows = $input.all();\nconst args = $('MCP Server Trigger').item.json.arguments;\nconst targetTime = args.startTime ? new Date(args.startTime) : null;\nconst windowHours = args.windowHours || 1;\n\nif (rows.length === 0 || !rows[0].json || !rows[0].json.Email) {\n  return [{ json: { status: 'not_found', found: false, message: 'Error: Appointment not found for the given email.' } }];\n}\n\n// If a startTime window is given, filter to the closest match\nlet match = rows[0].json;\nif (targetTime) {\n  const windowMs = windowHours * 60 * 60 * 1000;\n  const filtered = rows.filter(r => {\n    const rowTime = new Date(r.json.StartTime);\n    return Math.abs(rowTime - targetTime) <= windowMs;\n  });\n  if (filtered.length === 0) {\n    return [{ json: { status: 'not_found', found: false, message: 'Error: No appointment found in the specified time window.' } }];\n  }\n  match = filtered[0].json;\n}\n\nreturn [{\n  json: {\n    status: 'found',\n    found: true,\n    eventId: match.EventID,\n    email: match.Email,\n    name: match.Name || '',\n    startTime: match.StartTime,\n    appointmentStatus: match.Status,\n    message: `Appointment found. Event ID: ${match.EventID}`\n  }\n}];"
      }
    },

