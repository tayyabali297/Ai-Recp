    {
      "id": "aaaaaaaa-0007-0007-0007-000000000007",
      "name": "Calendar Get Events",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.2,
      "position": [740, 440],
      "credentials": { "googleCalendarOAuth2Api": { "id": "REPLACE_WITH_CREDENTIAL_ID", "name": "Google Calendar Account" } },
      "parameters": {
        "operation": "getAll",
        "calendar": { "__rl": true, "value": "primary", "mode": "list", "cachedResultName": "Primary" },
        "returnAll": true,
        "timeMin": "={{ $json.arguments.startTime }}",
        "timeMax": "={{ $json.arguments.endTime }}",
        "options": {
          "fields": "id,summary,start,end,status"
        }
