    {
      "id": "aaaaaaaa-0008-0008-0008-000000000008",
      "name": "Process Availability",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1000, 440],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Collect all calendar events in the requested window\nconst events = $input.all();\n\n// Build a list of busy slots\nconst busySlots = events\n  .filter(e => e.json && e.json.start)\n  .map(e => ({\n    start: e.json.start.dateTime || e.json.start.date,\n    end: e.json.end.dateTime || e.json.end.date,\n    summary: e.json.summary || 'Busy'\n  }));\n\n// Retrieve the requested window from the original trigger args\nconst triggerArgs = $('MCP Server Trigger').item.json.arguments;\nconst windowStart = new Date(triggerArgs.startTime);\nconst windowEnd   = new Date(triggerArgs.endTime);\n\n// Build candidate 1-hour slots (on the hour)\nconst availableSlots = [];\nlet cursor = new Date(windowStart);\ncursor.setMinutes(0, 0, 0);\nif (cursor < windowStart) cursor.setHours(cursor.getHours() + 1);\n\nwhile (cursor < windowEnd) {\n  const slotEnd = new Date(cursor.getTime() + 60 * 60 * 1000);\n  if (slotEnd > windowEnd) break;\n\n  // Check overlap with any busy event\n  const isBusy = busySlots.some(b => {\n    const bs = new Date(b.start);\n    const be = new Date(b.end);\n    return cursor < be && slotEnd > bs;\n  });\n\n  if (!isBusy) {\n    availableSlots.push({\n      start: cursor.toISOString(),\n      end: slotEnd.toISOString()\n    });\n  }\n  cursor = slotEnd;\n}\n\nreturn [{\n  json: {\n    status: 'success',\n    busySlots,\n    availableSlots,\n    message: availableSlots.length > 0\n      ? `Found ${availableSlots.length} available slot(s)`\n      : 'No available slots in the requested window'\n  }\n}];"
      }
    },

